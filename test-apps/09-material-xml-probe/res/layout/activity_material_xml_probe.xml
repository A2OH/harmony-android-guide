<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/probe_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#fffaf5">

    <TextView
        android:id="@+id/probe_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/probe_title"
        android:textColor="#202124"
        android:textSize="22sp" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/probe_input_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/probe_input"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:singleLine="true"
            android:text="@string/probe_input_text" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/probe_card"
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:layout_marginTop="12dp">

        <TextView
            android:id="@+id/probe_card_text"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:text="@string/probe_card_text"
            android:textColor="#3c4043"
            android:textSize="16sp" />
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/probe_chip_group"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <com.google.android.material.chip.Chip
            android:id="@+id/probe_chip_one"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="@string/probe_chip_one" />

        <com.google.android.material.chip.Chip
            android:id="@+id/probe_chip_two"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginLeft="8dp"
            android:text="@string/probe_chip_two" />
    </com.google.android.material.chip.ChipGroup>

    <com.google.android.material.slider.Slider
        android:id="@+id/probe_slider"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:max="100"
        android:progress="40" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/probe_button"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="16dp"
        android:text="@string/probe_button_text" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/probe_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginTop="12dp">

        <TextView
            android:id="@+id/probe_bottom_nav_text"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/probe_bottom_nav_text"
            android:textColor="#5f6368"
            android:textSize="14sp" />
    </com.google.android.material.bottomnavigation.BottomNavigationView>
</LinearLayout>
