+    /* Initialize System.out/err with native print streams */
+    {
+        // Create a minimal FileOutputStream for fd 1 (stdout)
+        // Then wrap in PrintStream and set as System.out
+        ClassObject* fosCls = dvmFindSystemClassNoInit("Ljava/io/FileOutputStream;");
+        ClassObject* psCls = dvmFindSystemClassNoInit("Ljava/io/PrintStream;");
+        ClassObject* fdCls = dvmFindSystemClassNoInit("Ljava/io/FileDescriptor;");
+        
+        if (fosCls && psCls && fdCls) {
+            // Create FileDescriptor for stdout (fd=1)
+            Object* fdOut = dvmAllocObject(fdCls, ALLOC_DEFAULT);
+            if (fdOut) {
+                InstField* descField = dvmFindInstanceFieldHier(fdCls, "descriptor", "I");
+                if (descField) dvmSetFieldInt(fdOut, descField->byteOffset, 1);
+                
+                // Create FileOutputStream wrapping the fd
+                Object* fos = dvmAllocObject(fosCls, ALLOC_DEFAULT);
+                if (fos) {
+                    InstField* fosField = dvmFindInstanceFieldHier(fosCls, "fd", "Ljava/io/FileDescriptor;");
+                    if (fosField) dvmSetFieldObject(fos, fosField->byteOffset, fdOut);
+                    
+                    // Create PrintStream wrapping the FileOutputStream
+                    Object* ps = dvmAllocObject(psCls, ALLOC_DEFAULT);
+                    if (ps) {
+                        InstField* psOut = dvmFindInstanceFieldHier(psCls, "out", "Ljava/io/OutputStream;");
+                        if (psOut) dvmSetFieldObject(ps, psOut->byteOffset, fos);
+                        
+                        // Set System.out
+                        StaticField* sysOut = dvmFindStaticField(gDvm.classJavaLangSystem, "out", "Ljava/io/PrintStream;");
+                        if (sysOut) {
+                            dvmSetStaticFieldObject(sysOut, ps);
+                            ALOGW("Initialized System.out");
+                        }
+                        // Set System.err (same stream for now)
+                        StaticField* sysErr = dvmFindStaticField(gDvm.classJavaLangSystem, "err", "Ljava/io/PrintStream;");
+                        if (sysErr) {
+                            dvmSetStaticFieldObject(sysErr, ps);
+                            ALOGW("Initialized System.err");
+                        }
+                        dvmReleaseTrackedAlloc(ps, NULL);
+                    }
+                    dvmReleaseTrackedAlloc(fos, NULL);
+                }
+                dvmReleaseTrackedAlloc(fdOut, NULL);
+            }
+        }
+        if (dvmCheckException(dvmThreadSelf())) dvmClearException(dvmThreadSelf());
+    }
+
     /* include self in non-daemon threads (mainly for AttachCurrentThread) */
     gDvm.nonDaemonThreadCount++;
 
@@ -3008,9 +3076,18 @@ static Object* getStaticThreadGroup(const char* fieldName)
     }
     groupObj = dvmGetStaticFieldObject(groupField);
     if (groupObj == NULL) {
