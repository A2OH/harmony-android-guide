-        dvmThrowInternalError(NULL);
-        return NULL;
+        ALOGW("ThreadGroup.%s null - creating stub", fieldName);
+        groupObj = dvmAllocObject(gDvm.classJavaLangThreadGroup, ALLOC_DEFAULT);
+        if (groupObj == NULL) { dvmThrowInternalError(NULL); return NULL; }
+        dvmSetStaticFieldObject(groupField, groupObj);
+        // Init essential fields
+        InstField* nf = dvmFindInstanceField(gDvm.classJavaLangThreadGroup, "name", "Ljava/lang/String;");
+        if (nf) { StringObject* s = dvmCreateStringFromCstr(fieldName);
+                   dvmSetFieldObject(groupObj, nf->byteOffset, (Object*)s);
+                   dvmReleaseTrackedAlloc((Object*)s, NULL); }
+        InstField* mp = dvmFindInstanceField(gDvm.classJavaLangThreadGroup, "maxPriority", "I");
+        if (mp) dvmSetFieldInt(groupObj, mp->byteOffset, 10);
+        dvmReleaseTrackedAlloc(groupObj, NULL);
     }
 
     return groupObj;
