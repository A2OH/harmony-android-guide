namespace android {

int register_android_view_SurfaceControl(JNIEnv* env) {
    jclass clazz = env->FindClass("android/view/SurfaceControl");
    if (clazz == nullptr) return -1;
    return env->RegisterNatives(clazz, gSurfaceControlMethods,
                                sizeof(gSurfaceControlMethods) / sizeof(JNINativeMethod));
}

// P13 new: SurfaceSession is a very small related class — Window uses it to
// create SurfaceControls. libandroid_runtime.so references this register
// function too. Provide an empty registration that at least satisfies the
// symbol, so JNI_OnLoad doesn't hit a null call.
int register_android_view_SurfaceSession(JNIEnv* /*env*/) {
    return 0;  // No native methods to register
}

