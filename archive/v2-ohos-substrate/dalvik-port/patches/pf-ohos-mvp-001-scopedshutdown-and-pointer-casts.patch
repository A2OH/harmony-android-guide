diff --git a/vm/Init.cpp b/vm/Init.cpp
index eaef0b9..371f498 100644
--- a/vm/Init.cpp
+++ b/vm/Init.cpp
@@ -1365,7 +1365,14 @@ public:
 
     ~ScopedShutdown() {
         if (armed_) {
-            dvmShutdown();
+            // PF-ohos-mvp-001 / issue #614: calling dvmShutdown() on a
+            // half-initialized VM SIGSEGVs and masks the real init error.
+            // Skip the cleanup and let JNI_CreateJavaVM surface the error
+            // string via ALOGW. The VM is about to be torn down by exit()
+            // anyway, so freeing partial subsystem state is moot.
+            fprintf(stderr, "[ScopedShutdown] dvmStartup failed; skipping "
+                    "dvmShutdown() to surface real error (issue #614)\n");
+            fflush(stderr);
         }
     }
 
