diff --git a/vm/Native.cpp b/vm/Native.cpp
index a12c4e0..f2d24de 100644
--- a/vm/Native.cpp
+++ b/vm/Native.cpp
@@ -67,7 +67,7 @@ void dvmNativeShutdown()
  * structure, but the declaration needs to match the DalvikBridgeFunc
  * type definition.)
  */
-void dvmResolveNativeMethod(const u4* args, JValue* pResult,
+void dvmResolveNativeMethod(const dreg_t* args, JValue* pResult,
     const Method* method, Thread* self)
 {
     ClassObject* clazz = method->clazz;
@@ -111,8 +111,11 @@ void dvmResolveNativeMethod(const u4* args, JValue* pResult,
     void* func = lookupSharedLibMethod(method);
     if (func != NULL) {
         /* found it, point it at the JNI bridge and then call it */
+        ALOGW("Found native %s.%s at %p, setting up JNI bridge", clazz->descriptor, method->name, func);
         dvmUseJNIBridge((Method*) method, func);
+        ALOGW("Calling native method via bridge (nativeFunc=%p)", method->nativeFunc);
         (*method->nativeFunc)(args, pResult, method, self);
